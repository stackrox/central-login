{
  "name": "central-login",
  "version": "1.0.0",
  "description": "A GitHub Action to configure login credentials for an ACS Central instance",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts' '**/*.yml'",
    "format-check": "prettier --check '**/*.ts' '**/*.yml'",
    "lint": "eslint src/**/*.ts --fix",
    "package": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --sourcemap",
    "all": "npm run build && npm run format && npm run lint && npm run package"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [],
  "author": "Red Hat",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/http-client": "^4.0.1",
    "axios": "^1.18.1",
    "is-retry-allowed": "^3.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.32.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-plugin-github": "^6.1.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
